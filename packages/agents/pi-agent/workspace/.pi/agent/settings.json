{
  "quietStartup": true,
  "defaultProvider": "openai",
  "defaultModel": "gpt-5.4-mini",
  "defaultThinkingModel": "medium",
  "packages": [
    "npm:@zhafron/pi-memory"
  ],
  "pi-memory": {
    "dashboard": false,
    "memoryDir": "~/.pi/agent/memory"
  },
  "retry": {
    "provider": {
      "timeoutMs": 30000
    }
  }
}
