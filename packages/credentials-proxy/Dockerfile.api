FROM node:22-slim AS build

RUN corepack enable && corepack prepare pnpm@latest --activate

WORKDIR /app

COPY package.json pnpm-workspace.yaml pnpm-lock.yaml tsconfig.base.json ./
COPY packages/credentials-proxy/package.json packages/credentials-proxy/
COPY packages/db/package.json packages/db/

RUN pnpm install --frozen-lockfile --filter credentials-proxy...

COPY packages/db/ packages/db/
COPY packages/credentials-proxy/ packages/credentials-proxy/

RUN pnpm --filter credentials-proxy build

FROM node:22-slim

WORKDIR /app
COPY --from=build /app/packages/credentials-proxy/dist ./dist

EXPOSE 10254

CMD ["node", "dist/api/index.js"]
